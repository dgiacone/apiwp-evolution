# URL base de Evolution API (sin barra final)
EVOLUTION_BASE_URL=http://35.195.28.12:8080
EVOLUTION_API_KEY=tu_apikey_aqui

# Puerto del backend de administración
ADMIN_PORT=8000

# URL pública donde Evolution debe enviar los eventos (POST).
# Debe coincidir con lo configurado en Evolution; si tu FastAPI está detrás del mismo host, usá esa URL.
WEBHOOK_PUBLIC_URL=http://35.195.28.12:8080/webhook/evolution

# Bootstrap automático: al iniciar, crea (si no existe) una instancia/sesión en Evolution
# asociada al teléfono indicado.
AUTO_SESSION_PHONE=+5493476201112
# Opcional: si se omite, se usa session-auto-<telefono_solo_digitos>
AUTO_SESSION_INSTANCE_NAME=
